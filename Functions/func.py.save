import random

list_1 = []
mid = len(list_1) // 2 - 1
n = int(input('Введите размер списка: '))
for i in range(n):
    list_1.append(random.randint(-20, 20))

print('Оригинальный список:', list_1)
print('Обратный список:', list_1[:mid:-1], list_1[mid::-1])



